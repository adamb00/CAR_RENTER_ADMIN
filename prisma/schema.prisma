generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  accounts  Account[]

  @@map("Users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("Accounts")
}

model Car {
  id            String          @id @default(cuid())
  manufacturer  String
  model         String
  seats         Int
  images        String[]        @default([])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  smallLuggage  Int             @default(0)
  largeLuggage  Int             @default(0)
  bodyType      CarBodyType     @default(sedan)
  fuel          CarFuel         @default(petrol)
  transmission  CarTransmission @default(manual)
  monthlyPrices Int[]           @default(dbgenerated("array_fill(0, ARRAY[12])"))
  fleetVehicles FleetVehicle[]
  colors        Color[]         @relation("CarColors")

  @@map("Cars")
}

model Color {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  cars      Car[]    @relation("CarColors")

  @@map("Colors")
}

model ContactQuotes {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locale             String
  name               String
  email              String
  phone              String
  preferredchannel   String
  rentalstart        DateTime?      @db.Date
  rentalend          DateTime?      @db.Date
  arrivalflight      String?
  departureflight    String?
  partysize          String?
  children           String?
  carid              String?
  carname            String?
  status             String         @default("new")
  updated            String?
  createdAt          DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt          DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  humanId            String?        @unique
  extras             String[]
  delivery           Json?
  bookingRequestData Json?
  rentaldays         Int?
  offerAccepted      Int?
  offerSent          DateTime?      @db.Date
  signerName         String?
  RentRequests       RentRequests[]

  @@index([createdAt], map: "idx_contactquotes_created_at")
  @@index([status], map: "idx_contactquotes_status")
}

model RentRequests {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locale                 String
  carid                  String?
  assignedFleetVehicleId String?
  assignedFleetPlate     String?
  renterId               String?                 @db.Uuid
  quoteid                String?                 @db.Uuid
  contactname            String
  contactemail           String
  contactphone           String?
  rentalstart            DateTime?               @db.Date
  rentalend              DateTime?               @db.Date
  status                 String                  @default("new")
  updated                String?
  payload                Json?
  createdAt              DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt              DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  archivedAt             DateTime?               @db.Timestamptz(6)
  humanId                String?                 @unique
  rentaldays             Int?
  signerName             String?
  ContactQuotes          ContactQuotes?          @relation(fields: [quoteid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  renter                 Renter?                 @relation(fields: [renterId], references: [id], onDelete: SetNull)
  vehicleHandovers       VehicleHandover[]
  bookingContract        BookingContract?
  bookingContractInvites BookingContractInvite[]
  bookingPricingSnapshot BookingPricingSnapshot?
  bookingDeliveryDetails BookingDeliveryDetails?
  bookingHandoverCosts   BookingHandoverCost[]

  @@index([carid], map: "idx_rentrequests_car")
  @@index([assignedFleetVehicleId], map: "idx_rentrequests_assigned_fleet_vehicle")
  @@index([renterId], map: "idx_rentrequests_renter")
  @@index([createdAt], map: "idx_rentrequests_created_at")
  @@index([status], map: "idx_rentrequests_status")
}

model Renter {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String?
  phone         String?
  taxId         String?
  companyName   String?
  paymentMethod String?
  primaryDriver Json?
  createdAt     DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt     DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @updatedAt @db.Timestamptz(6)
  bookings      RentRequests[]

  @@index([name], map: "idx_renters_name")
  @@map("Renters")
}

model BookingPricingSnapshot {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId   String       @unique @db.Uuid
  rentalFee   String?
  insurance   String?
  deposit     String?
  deliveryFee String?
  extrasFee   String?
  tip         String?
  createdAt   DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt   DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  booking     RentRequests @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId], map: "idx_booking_pricing_booking_id")
  @@map("BookingPricingSnapshots")
}

model BookingDeliveryDetails {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String       @unique @db.Uuid
  placeType       String?
  locationName    String?
  addressLine     String?
  island          String?
  arrivalFlight   String?
  departureFlight String?
  arrivalHour     String?
  arrivalMinute   String?
  createdAt       DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt       DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  booking         RentRequests @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId], map: "idx_booking_delivery_booking_id")
  @@index([island], map: "idx_booking_delivery_island")
  @@map("BookingDeliveryDetails")
}

model BookingHandoverCost {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String            @db.Uuid
  direction HandoverDirection?
  costType  HandoverCostType
  amount    Decimal           @db.Decimal(12, 2)
  createdAt DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  booking   RentRequests      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId], map: "idx_booking_handover_cost_booking_id")
  @@index([direction], map: "idx_booking_handover_cost_direction")
  @@index([bookingId, direction, costType, updatedAt, createdAt], map: "idx_booking_handover_cost_lookup")
  @@map("BookingHandoverCosts")
}

model BookingContract {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId           String       @unique @db.Uuid
  signerName          String
  signerEmail         String?
  contractVersion     String       @default("v1")
  contractText        String
  signatureData       String
  lessorSignatureData String?
  signedAt            DateTime     @default(now())
  pdfSentAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  booking             RentRequests @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("BookingContracts")
}

model BookingContractInvite {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId           String       @db.Uuid
  tokenHash           String       @unique
  recipientEmail      String
  signerName          String?
  locale              String?
  contractVersion     String       @default("v1")
  contractText        String
  lessorSignatureData String?
  expiresAt           DateTime
  sentAt              DateTime     @default(now())
  openedAt            DateTime?
  completedAt         DateTime?
  revokedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  booking             RentRequests @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId, completedAt, revokedAt, expiresAt])
  @@map("BookingContractInvites")
}

model Notification {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventKey    String    @unique(map: "notifications_event_key_key")
  type        String
  title       String
  description String
  href        String
  tone        String    @default("info")
  read        Boolean   @default(false)
  readAt      DateTime? @db.Timestamptz(6)
  metadata    Json?
  createdAt   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  notifyAt    DateTime? @db.Timestamptz(6)

  @@index([read, createdAt], map: "idx_notifications_read_created")
}

model FleetVehicle {
  id                 String            @id @default(cuid())
  carId              String
  plate              String            @unique
  odometer           Int               @default(0)
  serviceIntervalKm  Int?
  lastServiceMileage Int?
  lastServiceAt      DateTime?
  status             FleetStatus       @default(available)
  year               Int?
  firstRegistration  DateTime?
  location           String?
  vin                String?
  engineNumber       String?
  addedAt            DateTime          @default(now())
  inspectionExpiry   DateTime?
  notes              String?
  damages            String?
  damagesImages      String[]          @default([])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  car                Car               @relation(fields: [carId], references: [id], onDelete: Cascade)
  handovers          VehicleHandover[]

  @@map("FleetVehicles")
}

model VehicleHandover {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId      String            @db.Uuid
  fleetVehicleId String
  direction      HandoverDirection @default(out)
  handoverAt     DateTime          @default(now())
  handoverBy     String?
  mileage        Int?
  rangeKm        Int?
  notes          String?
  damages        String?
  damagesImages  String[]          @default([])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  booking        RentRequests      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fleetVehicle   FleetVehicle      @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([fleetVehicleId])
  @@map("VehicleHandovers")
}

enum CarBodyType {
  sedan
  hatchback
  suv
  wagon
  van
  pickup
  coupe
}

enum CarFuel {
  petrol
  diesel
  electric
  hybrid
}

enum CarTransmission {
  manual
  automatic
}

enum FleetStatus {
  available
  rented
  reserved
  maintenance
}

enum HandoverDirection {
  out
  in
}

enum HandoverCostType {
  tip
  fuel
  ferry
  cleaning
  commission
}
